#!/bin/sh
# Pre-commit hook: ruff check + ruff format --check (2층, 빠른 검사만)
# pyright + pytest → pre-push. CI(release.yml)에서 전체 게이트 재확인.

echo "[pre-commit] Running ruff..."

if ! uv run ruff check .; then
    echo "[pre-commit] ruff check failed. Fix issues and try again."
    exit 1
fi

if ! uv run ruff format --check .; then
    echo "[pre-commit] ruff format check failed."
    echo "[pre-commit] Run 'uv run ruff format .' to auto-fix formatting."
    exit 1
fi

echo "[pre-commit] All checks passed."
